@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VocabLab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VocabLab.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    
    <style>
        /* 1. HỆ THỐNG BIẾN MÀU TOÀN DIỆN */
        :root {
            --bg-body: #f8fafc;
            --bg-sidebar: transparent;
            --border-color: #e2e8f0;
            --text-main: #0f172a;
            --text-muted: #475569;
            --text-label: #64748b;
            --sidebar-hover: #e2e8f0;
            --sidebar-active-bg: #eeedfe;
            --sidebar-active-text: #6d28d9;
            --bg-widget: #ffffff;
            --shadow-widget: 0 1px 3px rgba(0,0,0,0.05);
        }

        [data-theme="dark"] {
            --bg-body: #0f172a;
            --bg-sidebar: transparent;
            --border-color: #2a2a3e;
            --text-main: #f8fafc;
            --text-muted: #cbd5e1;
            --text-label: #94a3b8;
            --sidebar-hover: #1e1e2e;
            --sidebar-active-bg: #2d2b55;
            --sidebar-active-text: #a78bfa;
            --bg-widget: #1e1e2e;
            --shadow-widget: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
            --modal-close-filter: invert(1) grayscale(1) brightness(2);
        }

        * { box-sizing: border-box; }

        body { 
            margin: 0; 
            display: flex; 
            flex-direction: column; 
            min-height: 100vh; 
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            -webkit-font-smoothing: antialiased;
            background: var(--bg-body); 
            color: var(--text-main);
            transition: background 0.3s ease, color 0.3s ease;
        }
        
        .app-wrapper { display: flex; flex: 1; }

        /* 2. SIDEBAR HOÀN TOÀN TRÀN VIỀN */
        .sidebar { 
            width: 250px; 
            background: var(--bg-sidebar); 
            border-right: none; 
            display: flex; 
            flex-direction: column; 
            min-height: 100vh; 
            position: fixed; 
            top: 0; 
            left: 0; 
            z-index: 100; 
            padding: 0 14px; 
        }
        
        .sidebar-logo { 
            padding: 1.75rem 0.75rem; 
            font-size: 22px; 
            font-weight: 800; 
            color: #6d28d9; 
            letter-spacing: -0.03em;
            text-transform: uppercase;
        }
        [data-theme="dark"] .sidebar-logo { color: #a78bfa; }
        .sidebar-logo i { font-size: 24px; vertical-align: -3px; margin-right: 6px; }
        
        .nav-item-side { 
            display: flex; 
            align-items: center; 
            gap: 14px; 
            padding: 14px 1rem; 
            font-size: 16px; 
            font-weight: 600;
            color: var(--text-muted); 
            text-decoration: none; 
            border-radius: 12px; 
            margin-bottom: 6px;
            transition: all 0.15s ease; 
        }
        .nav-item-side:hover { background: var(--sidebar-hover); color: var(--text-main); text-decoration: none; }
        .nav-item-side.active { background: var(--sidebar-active-bg); color: var(--sidebar-active-text); }
        .nav-item-side i { font-size: 20px; } 

        .sidebar-divider {
            height: 1px;
            background: var(--border-color);
            margin: 1rem 0.75rem;
        }
        
        /* 3. KHU VỰC ĐÁY SIDEBAR */
        .sidebar-footer { 
            margin-top: auto; 
            display: flex;
            flex-direction: column;
            gap: 12px;
            padding-bottom: 20px;
        }

        .profile-container-trigger {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px;
            border-radius: 14px;
            color: inherit;
            cursor: pointer;
            user-select: none;
            transition: background 0.15s;
        }
        .profile-container-trigger:hover { background: var(--sidebar-hover); }

        .avatar-wrapper-green {
            position: relative;
            padding: 2px;
            border: 2px solid #22c55e;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .avatar-circle { 
            width: 40px; 
            height: 40px; 
            border-radius: 50%; 
            background: var(--sidebar-active-bg); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-size: 16px; 
            font-weight: 700; 
            color: var(--sidebar-active-text); 
        }

        .profile-text { display: flex; flex-direction: column; overflow: hidden; flex-grow: 1; }
        .profile-main-name { 
            font-size: 15px; 
            font-weight: 700; 
            color: var(--text-main); 
            line-height: 1.3;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .profile-sub-link { font-size: 12px; color: var(--text-label); margin-top: 1px; }
        .profile-right-icon { color: var(--text-label); font-size: 18px; display: flex; align-items: center; }

        .bottom-widgets {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 8px;
        }

        .coin-widget {
            background: var(--bg-widget);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 700;
            color: #0284c7;
            box-shadow: var(--shadow-widget);
        }
        [data-theme="dark"] .coin-widget { color: #38bdf8; }
        .coin-widget i { color: #eab308; font-size: 18px; }

        .theme-toggle-widget {
            background: var(--bg-widget);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 700;
            color: var(--text-muted);
            cursor: pointer;
            box-shadow: var(--shadow-widget);
            user-select: none;
            transition: background 0.15s;
        }
        .theme-toggle-widget:hover { background: var(--sidebar-hover); }
        .theme-toggle-widget i { font-size: 16px; }
        
        .main-content { margin-left: 250px; flex: 1; padding: 2.5rem 3rem; width: calc(100% - 250px); }
        .footer-text { margin-top: 3rem; padding-top: 1.25rem; border-top: 1px solid var(--border-color); font-size: 13px; color: var(--text-label); }

        /* 4. CARD THÔNG TIN TRONG POPUP MODAL (FORM CHỈNH SỬA) */
        .detail-item-box {
            background: var(--bg-login);
            border: 1px solid var(--border-color);
            padding: 12px 16px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
        }
        .detail-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-label);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 4px;
        }
        .detail-value-static { 
            font-size: 15px; 
            font-weight: 700; 
            color: var(--text-label);
            padding: 6px 0;
        }
        .detail-input-edit {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 1px solid transparent;
            color: var(--text-main);
            font-size: 15px;
            font-weight: 600;
            padding: 4px 0;
            transition: border-color 0.2s;
        }
        .detail-input-edit:focus {
            outline: none;
            border-bottom-color: #6d28d9;
        }
        [data-theme="dark"] .detail-input-edit:focus { border-bottom-color: #a78bfa; }
    </style>
</head>
<body>
<div class="app-wrapper">

    <div class="sidebar">
        <div class="sidebar-logo">
            <i class="ti ti-book"></i>VocabLab
        </div>

        <a class="nav-item-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Home" asp-action="Index">
            <i class="ti ti-home"></i> Trang chủ
        </a>
        <a class="nav-item-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Word" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Word" asp-action="Index">
            <i class="ti ti-vocabulary"></i> Bộ từ vựng
        </a>
        <a class="nav-item-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Word" && ViewContext.RouteData.Values["action"]?.ToString() == "Quiz" ? "active" : "")"
           asp-controller="Word" asp-action="Quiz">
            <i class="ti ti-bolt"></i> Luyện tập
        </a>
        <a class="nav-item-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Leaderboard" ? "active" : "")"
           asp-controller="Leaderboard" asp-action="Index">
            <i class="ti ti-trophy"></i> Xếp hạng
        </a>
        <a class="nav-item-side" href="#">
            <i class="ti ti-settings"></i> Cài đặt
        </a>

        <div class="sidebar-divider"></div>

        <div class="sidebar-footer">
            @if (HttpContextAccessor.HttpContext.Request.Cookies.TryGetValue("vocab_user", out var loggedInUser))
            {
                <div class="profile-container-trigger" data-bs-toggle="modal" data-bs-target="#userProfileModal">
                    <div class="avatar-wrapper-green">
                        <div class="avatar-circle">@loggedInUser.Substring(0, 1).ToUpper()</div>
                    </div>
                    <div class="profile-text">
                        <div class="profile-main-name">@loggedInUser</div>
                        <div class="profile-sub-link">Nhấn để xem hồ sơ</div>
                    </div>
                    <div class="profile-right-icon">
                        <i class="ti ti-user-scan"></i>
                    </div>
                </div>
            }
            else
            {
                <a class="nav-item-side" asp-controller="Account" asp-action="Login">
                    <i class="ti ti-login"></i> Đăng nhập tài khoản
                </a>
            }

            <div class="bottom-widgets">
                <div class="coin-widget" title="Điểm tích lũy">
                    <i class="ti ti-coin-filled"></i>
                    <span>12,049</span>
                </div>
                
                <div class="theme-toggle-widget" id="btnThemeToggle">
                    <i class="ti ti-sun" id="themeWidgetIcon"></i>
                    <span id="themeWidgetText">Sáng</span>
                </div>
            </div>
        </div>
    </div>

    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>

        <footer class="footer-text">
            &copy; 2026 - VocabLab
        </footer>
    </div>

</div>

<div class="modal fade" id="userProfileModal" tabindex="-1" aria-labelledby="userProfileModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 400px;">
        <div class="modal-content" style="background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 20px; color: var(--text-main); overflow: hidden;">
            
            <div class="modal-header border-0 pb-0" style="padding: 20px 20px 10px;">
                <h5 class="modal-title fw-bold" id="userProfileModalLabel" style="font-size: 18px;">🪪 Hồ Sơ Học Viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="filter: var(--modal-close-filter, none);"></button>
            </div>
            
            <div class="modal-body" style="padding: 10px 20px 20px;">
                <form id="profileEditForm" onsubmit="saveProfileChanges(event)">
                    <div class="d-flex flex-column gap-3">
                        
                        <div class="detail-item-box" style="background: rgba(0,0,0,0.02);">
                            <span class="detail-label">Tên người học (Cố định)</span>
                            <div class="detail-value-static">
                                <i class="ti ti-lock" style="font-size: 14px; margin-right: 4px;"></i>
                                @(HttpContextAccessor.HttpContext.Request.Cookies.TryGetValue("vocab_user", out var userVal) ? userVal : "Học viên")
                            </div>
                        </div>

                        <div class="detail-item-box">
                            <label class="detail-label" for="inputLanguage">Ngôn ngữ đang học</label>
                            <input type="text" id="inputLanguage" class="detail-input-edit" 
                                   value="@(HttpContextAccessor.HttpContext.Request.Cookies.TryGetValue("vocab_lang", out var lang) ? lang : "Tiếng Anh (English)")" required />
                        </div>

                        <div class="detail-item-box">
                            <label class="detail-label" for="inputExam">Tên cuộc thi mục tiêu</label>
                            <input type="text" id="inputExam" class="detail-input-edit" style="color: #6d28d9; font-weight: 700;"
                                   value="@(HttpContextAccessor.HttpContext.Request.Cookies.TryGetValue("vocab_exam", out var exam) ? exam : "Đánh giá năng lực / Học kỳ OOP")" required />
                        </div>

                        <div class="detail-item-box">
                            <label class="detail-label" for="inputExamDate">Ngày thi dự kiến</label>
                            <input type="text" id="inputExamDate" class="detail-input-edit" style="font-family: monospace;"
                                   value="@(HttpContextAccessor.HttpContext.Request.Cookies.TryGetValue("vocab_date", out var date) ? date : "24 / 06 / 2026")" required />
                        </div>

                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary w-100" style="border-radius: 10px; font-weight: 600; padding: 10px; background: #6d28d9; border: none;">
                            💾 Lưu thay đổi hồ sơ
                        </button>
                    </div>
                </form>

                <div class="mt-2 pt-2" style="border-top: 1px dashed var(--border-color);">
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2" style="border-radius: 10px; font-weight: 600; padding: 8px;">
                        <i class="ti ti-logout"></i> Đăng xuất tài khoản
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

<script>
    // Hàm lưu thông tin hồ sơ chỉnh sửa trực tiếp vào Cookie mà không cần tải lại Backend nặng nề
    function saveProfileChanges(event) {
        event.preventDefault();
        
        const langVal = document.getElementById("inputLanguage").value;
        const examVal = document.getElementById("inputExam").value;
        const dateVal = document.getElementById("inputExamDate").value;
        
        // Thiết lập Cookie lưu trong 30 ngày công khai
        const maxAge = 30 * 24 * 60 * 60;
        document.cookie = `vocab_lang=${encodeURIComponent(langVal)}; max-age=${maxAge}; path=/`;
        document.cookie = `vocab_exam=${encodeURIComponent(examVal)}; max-age=${maxAge}; path=/`;
        document.cookie = `vocab_date=${encodeURIComponent(dateVal)}; max-age=${maxAge}; path=/`;
        
        // Hiện thông báo thành công và reload lại trang để giao diện Modal cập nhật dữ liệu mới liền
        alert("🎉 Cập nhật thông tin hồ sơ cá nhân thành công!");
        window.location.reload();
    }

    document.addEventListener("DOMContentLoaded", function () {
        const toggleBtn = document.getElementById("btnThemeToggle");
        const themeIcon = document.getElementById("themeWidgetIcon");
        const themeText = document.getElementById("themeWidgetText");

        function applyTheme(theme) {
            document.documentElement.setAttribute("data-theme", theme);
            localStorage.setItem("theme", theme);
            
            if (theme === "dark") {
                themeIcon.className = "ti ti-moon";
                themeText.textContent = "Tối";
            } else {
                themeIcon.className = "ti ti-sun";
                themeText.textContent = "Sáng";
            }
        }

        const initialTheme = localStorage.getItem("theme") || "light";
        applyTheme(initialTheme);

        toggleBtn.addEventListener("click", function () {
            const currentTheme = document.documentElement.getAttribute("data-theme");
            const newTheme = currentTheme === "light" ? "dark" : "light";
            applyTheme(newTheme);
        });
    });
</script>
</body>
</html>
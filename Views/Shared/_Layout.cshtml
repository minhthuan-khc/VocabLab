<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VocabLab</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VocabLab.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; display: flex; flex-direction: column; min-height: 100vh; font-family: sans-serif; background: #f5f5f0; }
        .app-wrapper { display: flex; flex: 1; }

        /* SIDEBAR */
        .sidebar { width: 220px; background: #fff; border-right: 1px solid #e5e5e0; display: flex; flex-direction: column; min-height: 100vh; position: fixed; top: 0; left: 0; z-index: 100; }
        .sidebar-logo { padding: 1.25rem; font-size: 18px; font-weight: 600; color: #534AB7; border-bottom: 1px solid #e5e5e0; }
        .sidebar-logo i { font-size: 20px; vertical-align: -3px; margin-right: 6px; }
        .nav-item-side { display: flex; align-items: center; gap: 10px; padding: 11px 1.25rem; font-size: 14px; color: #555; text-decoration: none; transition: background 0.15s; }
        .nav-item-side:hover { background: #f5f5f0; color: #222; text-decoration: none; }
        .nav-item-side.active { background: #EEEDFE; color: #534AB7; font-weight: 500; }
        .nav-item-side i { font-size: 18px; }
        .sidebar-footer { margin-top: auto; padding: 1rem 1.25rem; border-top: 1px solid #e5e5e0; display: flex; align-items: center; gap: 10px; }
        .avatar { width: 36px; height: 36px; border-radius: 50%; background: #EEEDFE; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #534AB7; flex-shrink: 0; }

        /* MAIN */
        .main-content { margin-left: 220px; flex: 1; padding: 1.5rem 2rem; width: calc(100% - 220px); }
    </style>
</head>
<body>
<div class="app-wrapper">

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <i class="ti ti-book"></i>VocabLab
        </div>

        <a class="nav-item-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           asp-controller="Home" asp-action="Index">
            <i class="ti ti-home"></i> Trang chủ
        </a>
        <a class="nav-item-side @(ViewContext.RouteData.Values["controller"]?.ToString() == "Word" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Word" asp-action="Index">
            <i class="ti ti-vocabulary"></i> Từ vựng
        </a>
        <a class="nav-item-side @(ViewContext.RouteData.Values["action"]?.ToString() == "Quiz" ? "active" : "")"
           asp-controller="Word" asp-action="Quiz">
            <i class="ti ti-bolt"></i> Luyện tập
        </a>
        <a class="nav-item-side"
           asp-controller="Home" asp-action="Privacy">
            <i class="ti ti-trophy"></i> Xếp hạng
        </a>
        <a class="nav-item-side"
           asp-controller="Home" asp-action="Privacy">
            <i class="ti ti-settings"></i> Cài đặt
        </a>

        <div class="sidebar-footer">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                <div>
                    <div style="font-size:13px;font-weight:500">@User.Identity.Name</div>
                    <div style="font-size:11px;color:#888">Đã đăng nhập</div>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" style="font-size:13px;color:#534AB7">
                    <i class="ti ti-login"></i> Đăng nhập
                </a>
            }
        </div>
    </div>

    <!-- NỘI DUNG CHÍNH -->
    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>

        <footer style="margin-top:2rem;padding-top:1rem;border-top:1px solid #e5e5e0;font-size:12px;color:#999">
            &copy; 2026 - VocabLab
        </footer>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
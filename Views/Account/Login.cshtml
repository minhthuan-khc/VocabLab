@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<style>
    :root {
        --bg-login: #f8fafc;
        --bg-card: #ffffff;
        --border-color: #e2e8f0;
        --text-main: #0f172a;
        --text-label: #64748b;
        --shadow-box: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
    }

    [data-theme="dark"] {
        --bg-login: #0f172a;
        --bg-card: #1e293b;
        --border-color: #334155;
        --text-main: #f8fafc;
        --text-label: #94a3b8;
        --shadow-box: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
    }

    .login-page-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Inter', sans-serif;
    }

    .login-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        width: 100%;
        max-width: 420px;
        padding: 2.5rem;
        box-shadow: var(--shadow-box);
    }

    .login-header { text-align: center; margin-bottom: 2rem; }
    .login-brand { font-size: 26px; font-weight: 800; color: #6d28d9; letter-spacing: -0.03em; }
    [data-theme="dark"] .login-brand { color: #a78bfa; }
    .login-subtitle { font-size: 13px; color: var(--text-label); margin-top: 4px; }

    .input-wrapper { margin-bottom: 1.25rem; }
    .input-label { font-size: 12px; font-weight: 700; color: var(--text-label); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; display: block; }
    
    .login-input {
        width: 100%;
        background: var(--bg-login);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 12px 16px;
        border-radius: 10px;
        font-size: 15px;
        transition: all 0.2s;
    }
    .login-input:focus {
        background: var(--bg-card);
        border-color: #6d28d9;
        outline: none;
        box-shadow: 0 0 0 3px rgba(109, 40, 217, 0.15);
    }

    .btn-submit-login {
        width: 100%;
        background: #6d28d9;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-submit-login:hover { opacity: 0.9; }

    .login-footer-links { text-align: center; margin-top: 1.5rem; font-size: 14px; color: var(--text-label); }
    .login-footer-links a { color: #6d28d9; font-weight: 600; text-decoration: none; }
    [data-theme="dark"] .login-footer-links a { color: #a78bfa; }
</style>

<div class="login-page-container">
    <div class="login-card">
        
        <div class="login-header">
            <div class="login-brand"><i class="ti ti-lock-access"></i> VocabLab</div>
            <div class="login-subtitle">Đăng nhập để tiếp tục hành trình học tập</div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-3 small rounded-3 d-flex align-items-center gap-2" style="background-color: #fee2e2; color: #991b1b; padding: 10px 14px;">
                <i class="ti ti-circle-x-filled" style="font-size: 18px;"></i>
                <div>@TempData["ErrorMessage"]</div>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-3 small rounded-3 d-flex align-items-center gap-2" style="background-color: #dcfce7; color: #166534; padding: 10px 14px;">
                <i class="ti ti-circle-check-filled" style="font-size: 18px;"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            
            <div class="input-wrapper">
                <label class="input-label">ID người dùng</label>
                <input type="text" name="Username" class="login-input" placeholder="Nhập ID của bạn..." required />
            </div>

            <div class="input-wrapper">
                <label class="input-label">Mật khẩu</label>
                <input type="password" name="Password" class="login-input" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-submit-login">
                <i class="ti ti-login"></i> Đăng Nhập
            </button>
        </form>

        <div class="login-footer-links">
            Chưa có tài khoản? <a href="@Url.Action("Register", "Account")">Đăng ký ngay</a>
        </div>

    </div>
</div>
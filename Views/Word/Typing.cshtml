@{ ViewData["Title"] = "Luyện viết từ vựng"; }

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    /* Hệ thống bộ màu tự động linh hoạt theo Light/Dark Mode */
    :root {
        --bg-app: #f8fafc;          
        --bg-card: #ffffff;          
        --text-main: #1e293b;       
        --text-card: #0f172a;        
        --text-muted: #64748b;       
        --bg-topbar: rgba(0, 0, 0, 0.8); 
        --text-topbar: #ffffff;
        --border-input: #38bdf8;     
        --bg-input: #f1f5f9;         
        --text-input: #0f172a;       
        --border-card: rgba(128, 128, 128, 0.2);
        --bg-btn-action: #f1f5f9;    
        --text-btn-action: #334155;
    }

    [data-theme="dark"] {
        --bg-app: #0f172a;          
        --bg-card: #1e293b;          
        --text-main: #f8fafc;       
        --text-card: #ffffff;        
        --text-muted: #94a3b8;       
        --bg-topbar: rgba(0, 0, 0, 0.5); 
        --text-topbar: #cbd5e1;
        --border-input: #0284c7;     
        --bg-input: rgba(0, 0, 0, 0.3); 
        --text-input: #ffffff;       
        --border-card: transparent;
        --bg-btn-action: rgba(255, 255, 255, 0.05); 
        --text-btn-action: #cbd5e1;
    }

    .game-wrapper {
        background-color: var(--bg-app);
        min-height: 100vh;
        padding: 2rem 1rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-main);
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Top Bar tiến độ */
    .top-bar-container {
        width: 100%;
        max-width: 550px;
        background: var(--bg-topbar);
        border-radius: 24px;
        padding: 15px 24px;
        color: var(--text-topbar);
        margin-bottom: 2rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
    .top-bar-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 14px;
        margin-bottom: 10px;
    }
    .toggle-switch-mode {
        background: rgba(255,255,255,0.2);
        padding: 2px 10px;
        border-radius: 15px;
        font-size: 12px;
        font-weight: bold;
    }
    .top-bar-row a {
        color: inherit;
        text-decoration: none;
        opacity: 0.8;
    }
    .top-bar-row a:hover { opacity: 1; }

    .progress-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 12px;
    }
    .game-badge {
        background: #f59e0b;
        color: black;
        font-weight: bold;
        padding: 2px 8px;
        border-radius: 10px;
    }
    .progress-bar-bg {
        flex: 1;
        background: rgba(255,255,255,0.15);
        height: 6px;
        border-radius: 3px;
        overflow: hidden;
    }
    .progress-bar-fill {
        background: #22c55e;
        width: 0%; 
        height: 100%;
        border-radius: 3px;
        transition: width 0.3s ease;
    }

    /* Khối Typing Card chính */
    .typing-card {
        width: 100%;
        max-width: 550px;
        background-color: var(--bg-card);
        color: var(--text-card);
        border: 1px solid var(--border-card);
        border-radius: 32px;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    .hint-vie-title {
        font-weight: 700;
        margin-bottom: 0.5rem;
        text-align: center;
        line-height: 1.3;
        max-width: 100%;
    }
    .font-single { font-size: 1.8rem; }
    .font-multi  { font-size: 1.4rem; }

    .meta-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1.5rem;
    }
    .btn-audio-small {
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: 16px;
        cursor: pointer;
    }
    .btn-audio-small:hover { color: var(--text-card); }
    
    .word-type-tag {
        background: rgba(128, 128, 128, 0.15);
        color: var(--text-muted);
        font-size: 11px;
        font-weight: bold;
        padding: 3px 10px;
        border-radius: 6px;
        text-transform: uppercase;
    }

    /* Ô gõ Input */
    .typing-input-wrapper {
        width: 100%;
        max-width: 420px;
        margin-bottom: 1.5rem;
    }
    .typing-input {
        width: 100%;
        background: var(--bg-input);
        border: 2px solid transparent;
        border-radius: 20px;
        padding: 12px 20px;
        color: var(--text-input);
        font-size: 1.1rem;
        text-align: center;
        outline: none;
        transition: border-color 0.2s, background-color 0.3s;
    }
    .typing-input:focus {
        border-color: var(--border-input);
        background: var(--bg-card);
    }

    /* THANH NGANG ĐÁP ÁN (Giải thích nghĩa + Ví dụ + Mức độ khó) */
    .result-bar {
        width: 100%;
        max-width: 420px;
        border-radius: 16px;
        padding: 14px 18px;
        margin-bottom: 1.5rem;
        display: none; 
        text-align: left;
        animation: slideDown 0.2s ease-out;
    }
    .result-bar.success {
        background-color: rgba(34, 197, 94, 0.12);
        border: 1px solid #22c55e;
        color: #16a34a;
    }
    .result-bar.danger {
        background-color: rgba(239, 68, 68, 0.12);
        border: 1px solid #ef4444;
        color: #dc2626;
    }
    .result-status-title {
        font-weight: bold;
        font-size: 14px;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        justify-content: space-between; /* Để đẩy tag mức độ khó sang bên phải */
    }
    .difficulty-badge {
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: bold;
        background: rgba(245, 158, 11, 0.2);
        color: #f59e0b;
    }
    .result-info-text {
        font-size: 13.5px;
        line-height: 1.5;
        color: var(--text-card);
    }
    .result-info-text .example-block {
        margin-top: 6px;
        padding-top: 6px;
        border-top: 1px dashed rgba(128, 128, 128, 0.2);
        font-style: italic;
        color: var(--text-muted);
    }

    /* Hàng nút chức năng điều khiển */
    .action-buttons-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
        max-width: 420px;
    }
    .btn-action-item {
        background: var(--bg-btn-action);
        border: 1px solid var(--border-card);
        color: var(--text-btn-action);
        border-radius: 20px;
        padding: 8px 16px;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        transition: background 0.2s;
    }
    .btn-action-item:hover { opacity: 0.85; }
    .btn-action-item span.btn-text { font-size: 13px; font-weight: 600; }
    .btn-action-item span.btn-hotkey { font-size: 10px; color: var(--text-muted); margin-top: 2px; }

    .btn-action-item.btn-check { background: #22c55e; border: none; color: white; }
    .btn-action-item.btn-check:hover { background: #16a34a; }
    .btn-action-item.btn-check span.btn-hotkey { color: rgba(255, 255, 255, 0.8); }

    /* Dùng @@ để tránh lỗi biên dịch Razor CS0103 */
    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="game-wrapper">
    <div class="top-bar-container">
        <div class="top-bar-row">
            <div id="game-counter" style="font-weight: bold;">Câu 1 / 20</div>
            <div class="toggle-switch-mode">VN &rarr; EN</div>
            <div>
                <a href="javascript:void(0)" onclick="restartGame()" style="margin-right: 15px;"><i class="bi bi-arrow-clockwise"></i> Chơi lại</a>
                <a href="/Word/Quiz"><i class="bi bi-box-arrow-right"></i> Thoát</a>
            </div>
        </div>
        <div class="progress-wrapper">
            <span class="game-badge">&sim;0 GAME</span>
            <span id="timer-text" style="color: #22c55e; font-weight: bold;">28s</span>
            <div class="progress-bar-bg">
                <div class="progress-bar-fill" id="progress-fill"></div>
            </div>
        </div>
    </div>

    <div class="typing-card">
        <div class="hint-vie-title" id="hint-vie">tuyên bố; trạng thái</div>
        
        <div class="meta-row">
            <button class="btn-audio-small" onclick="playTargetAudio()"><i class="bi bi-volume-up-fill"></i></button>
            <div class="word-type-tag" id="word-type">VERB/NOUN</div>
        </div>

        <div class="typing-input-wrapper">
            <input type="text" id="user-input" class="typing-input" autocomplete="off" placeholder="Gõ từ tiếng Anh..." />
        </div>

        <div class="result-bar" id="result-bar">
            <div class="result-status-title">
                <span id="result-title"></span>
                <span class="difficulty-badge" id="word-difficulty">Độ khó: B1</span>
            </div>
            <div class="result-info-text" id="result-info"></div>
        </div>

        <div class="action-buttons-row">
            <button class="btn-action-item" onclick="showLetterHint()">
                <span class="btn-text"><i class="bi bi-lightbulb"></i> Gợi ý tự động</span>
                <span class="btn-hotkey">Ctrl + Space</span>
            </button>
            
            <button class="btn-action-item btn-check" onclick="checkAnswer()">
                <span class="btn-text">Kiểm tra</span>
                <span class="btn-hotkey">Enter</span>
            </button>
        </div>
    </div>
</div>

<script>
    let words = [];
    let index = 0;
    let timerValue = 30;
    let timerInterval = null;
    let isWaitingNext = false; 

    async function initTyping() {
        try {
            const res = await fetch('/Word/GetWordsForGame?count=10');
            words = await res.json();
            
            if(words && words.length > 0) {
                showCurrentCard();
            } else {
                initMockData();
            }
        } catch (e) {
            initMockData();
        }
        startTimer();
    }

    function initMockData() {
        words = [
            { english: "state", vietnamese: "tuyên bố; trạng thái", type: "VERB/NOUN", difficulty: "Cơ bản", example: 'Ví dụ: "The system is in a stable state."', audioUrl: "" },
            { english: "branch", vietnamese: "chi nhánh công ty thành viên", type: "NOUN", difficulty: "Trung bình", example: 'Ví dụ: "Our company opened a new branch in Hanoi."', audioUrl: "" }
        ];
        showCurrentCard();
    }

    function startTimer() {
        clearInterval(timerInterval);
        timerValue = 30;
        document.getElementById("timer-text").innerText = `${timerValue}s`;
        
        timerInterval = setInterval(() => {
            if(!isWaitingNext) {
                timerValue--;
                document.getElementById("timer-text").innerText = `${timerValue}s`;
                if(timerValue <= 0) {
                    clearInterval(timerInterval);
                }
            }
        }, 1000);
    }

    function showCurrentCard() {
        isWaitingNext = false;
        if(index >= words.length) {
            clearInterval(timerInterval);
            alert("Xuất sắc! Bạn đã hoàn thành phần luyện viết từ.");
            restartGame();
            return;
        }

        const currentWord = words[index];
        
        document.getElementById("game-counter").innerText = `Câu ${index + 1} / ${words.length}`;
        const percent = ((index + 1) / words.length) * 100;
        document.getElementById("progress-fill").style.width = `${percent}%`;

        // Reset ẩn thanh kết quả
        document.getElementById("result-bar").style.display = "none";

        const hintVieElem = document.getElementById("hint-vie");
        hintVieElem.innerText = currentWord.vietnamese;
        
        const wordCount = currentWord.vietnamese.trim().split(/\s+/).length;
        hintVieElem.classList.remove('font-single', 'font-multi');
        if (wordCount >= 2 || currentWord.vietnamese.length > 15) {
            hintVieElem.classList.add('font-multi');
        } else {
            hintVieElem.classList.add('font-single');
        }

        document.getElementById("word-type").innerText = currentWord.type || "NOUN";

        const inp = document.getElementById("user-input");
        inp.value = "";
        inp.disabled = false;
        inp.focus();
        startTimer();
    }

    function checkAnswer() {
        if(isWaitingNext) return; 

        const inp = document.getElementById("user-input");
        const target = words[index].english.trim().toLowerCase();
        const current = inp.value.trim().toLowerCase();
        
        const resultBar = document.getElementById("result-bar");
        const resultTitle = document.getElementById("result-title");
        const resultInfo = document.getElementById("result-info");
        const diffBadge = document.getElementById("word-difficulty");

        resultBar.classList.remove("success", "danger");
        
        // Đổ độ khó của từ từ Object database
        diffBadge.innerText = `Độ khó: ${words[index].difficulty || "A2"}`;

        if(current === target) {
            // ĐÚNG -> THANH XANH
            isWaitingNext = true;
            inp.disabled = true; 
            
            resultBar.classList.add("success");
            resultBar.style.display = "block";
            resultTitle.innerHTML = '<i class="bi bi-check-circle-fill"></i> Chính xác!';
            
            resultInfo.innerHTML = `
                <div><strong>${words[index].english}</strong> (${words[index].type || 'n'}): ${words[index].vietnamese}</div>
                <div class="example-block">${words[index].Example || "Chưa có câu ví dụ."}</div>
            `;
            
            index++;
            setTimeout(showCurrentCard, 2500); // Chờ 2.5s chuyển câu để kịp đọc giải nghĩa
        } else {
            // SAI -> THANH ĐỎ
            resultBar.classList.add("danger");
            resultBar.style.display = "block";
            resultTitle.innerHTML = '<i class="bi bi-x-circle-fill"></i> Chưa chính xác!';
            
            resultInfo.innerHTML = `
                <div>Đáp án đúng: <strong style="text-decoration: underline;">${words[index].english}</strong></div>
                <div>Nghĩa: ${words[index].vietnamese}</div>
                <div class="example-block">${words[index].Example || "Chưa có câu ví dụ."}</div>
            `;
            inp.focus();
        }
    }

    function showLetterHint() {
        if(isWaitingNext) return;
        const target = words[index].english;
        const inp = document.getElementById("user-input");
        inp.value = target.substring(0, 1); 
        inp.focus();
    }

    function playTargetAudio() {
        let utterance = new SpeechSynthesisUtterance(words[index].english);
        utterance.lang = 'en-US';
        window.speechSynthesis.speak(utterance);
    }

    function restartGame() {
        index = 0;
        showCurrentCard();
    }

    document.addEventListener("keydown", function(e) {
        if (e.ctrlKey && e.code === 'Space') {
            e.preventDefault();
            showLetterHint();
        }
        if (e.key === "Enter" && document.activeElement.id === "user-input") {
            e.preventDefault();
            checkAnswer();
        }
    });

    document.addEventListener("DOMContentLoaded", initTyping);
</script>
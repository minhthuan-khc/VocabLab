@model Word

@{ 
    ViewData["Title"] = "Thêm Từ Vựng Mới";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="row justify-content-center">
        <div class="col-12"> 
            <h2 class="mb-4" style="font-weight: 700; color: var(--text-main); letter-spacing: -0.02em;">✨ Thêm Từ Vựng Mới</h2>

            <div class="tab-navigation-bar mb-4">
                <button type="button" class="tab-btn active" id="btnManual" onclick="switchTab('manualForm', this)">
                    <i class="ti ti-edit"></i> Nhập Thủ Công
                </button>
                <button type="button" class="tab-btn" id="btnAuto" onclick="switchTab('autoForm', this)">
                    <i class="ti ti-bolt"></i> Nhập Nhanh 1 Từ
                </button>
                <button type="button" class="tab-btn" id="btnMulti" onclick="switchTab('multiForm', this)">
                    <i class="ti ti-forms"></i> Nhập Nhiều Từ (Bulk)
                </button>
            </div>

            <div id="manualForm" class="form-section-box">
                <form action="/Word/Create" method="post">
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="Term" class="custom-form-label">Từ Tiếng Anh *</label>
                            <input id="Term" name="Term" class="custom-form-input" placeholder="Ví dụ: filing cabinet" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="Pronunciation" class="custom-form-label">Phát âm (Phiên âm)</label>
                            <input id="Pronunciation" name="Pronunciation" class="custom-form-input" placeholder="Ví dụ: /ˈfaɪ.lɪŋ ˌkæb.ə.nət/" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="Definition" class="custom-form-label">Định Nghĩa (Nghĩa tiếng Việt) *</label>
                        <input id="Definition" name="Definition" class="custom-form-input" placeholder="Ví dụ: tủ hồ sơ" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="Category" class="custom-form-label">Thể Loại (Từ loại) *</label>
                            <input id="Category" name="Category" class="custom-form-input" placeholder="Ví dụ: NOUN, VERB..." required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="DifficultyLevel" class="custom-form-label">Độ Khó</label>
                            <select id="DifficultyLevel" name="DifficultyLevel" class="custom-form-input select-arrow">
                                <option value="1">🟢 Dễ</option>
                                <option value="2" selected>🟡 Trung Bình</option>
                                <option value="3">🔴 Khó</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="Example" class="custom-form-label">Ví Dụ Thực Tế</label>
                        <textarea id="Example" name="Example" class="custom-form-input pt-2" rows="2" placeholder="Ví dụ: Old contracts are stored in the filing cabinet."></textarea>
                    </div>

                    <div class="action-btn-group">
                        <button type="submit" class="save-btn"><i class="ti ti-device-floppy"></i> Lưu Từ Vựng</button>
                        <a href="@Url.Action("Index", "Word")" class="cancel-btn">Hủy bỏ</a>
                    </div>
                </form>
            </div>

            <div id="autoForm" class="form-section-box d-none">
                <div class="mb-3">
                    <label class="custom-form-label">Cú pháp phân tách nhanh *</label>
                    <input type="text" class="custom-form-input accent-input" id="autoTerm" placeholder="Từ vựng | Phát âm | Định nghĩa | Từ loại | Ví dụ | Độ khó">
                    <small class="hint-text">Cấu trúc mẫu: laptop | /ˈlæp.tɒp/ | máy tính xách tay | NOUN | This is my laptop | Dễ</small>
                </div>
                <button type="button" class="process-btn mb-4" onclick="parseQuickInput()"><i class="ti ti-wand"></i> Phân tích cú pháp</button>
                
                <div id="autoResult" class="d-none pt-3" style="border-top: 1px dashed var(--border-color)">
                    <form action="/Word/Create" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-md-6 mb-3"><label class="custom-form-label">Từ vựng</label><input type="text" class="custom-form-input" id="resultTerm" name="Term" readonly></div>
                            <div class="col-md-6 mb-3"><label class="custom-form-label">Phát âm</label><input type="text" class="custom-form-input" id="resultPronunciation" name="Pronunciation"></div>
                        </div>
                        <div class="mb-3"><label class="custom-form-label">Định Nghĩa</label><input type="text" class="custom-form-input" id="resultDefinition" name="Definition" required></div>
                        <div class="row">
                            <div class="col-md-6 mb-3"><label class="custom-form-label">Thể Loại</label><input type="text" class="custom-form-input" id="resultCategory" name="Category" required></div>
                            <div class="col-md-6 mb-3">
                                <label class="custom-form-label">Độ Khó</label>
                                <select id="resultDifficultyLevel" name="DifficultyLevel" class="custom-form-input">
                                    <option value="1">Dễ</option><option value="2">Trung Bình</option><option value="3">Khó</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-4"><label class="custom-form-label">Ví Dụ</label><textarea class="custom-form-input pt-2" id="resultExample" name="Example" rows="2"></textarea></div>
                        <button type="submit" class="save-btn w-100"><i class="ti ti-device-floppy"></i> Lưu Từ Vựng</button>
                    </form>
                </div>
            </div>

            <div id="multiForm" class="form-section-box d-none">
                <div class="mb-3">
                    <label class="custom-form-label">Nhập danh sách từ vựng (Mỗi từ nằm trên 1 dòng) *</label>
                    <textarea class="custom-form-input pt-2 font-monospace" id="multiTerm" rows="6" placeholder="laptop | /ˈlæp.tɒp/ | máy tính xách tay | NOUN | My new laptop | Dễ&#10;monitor | /ˈmɒn.ɪ.tər/ | màn hình máy tính | NOUN | Large monitor | Trung Bình"></textarea>
                    <small class="hint-text">Định dạng phân tách bằng dấu gạch đứng (|). Xuống dòng (Enter) để thêm từ tiếp theo.</small>
                </div>

                <button type="button" class="process-btn mb-4" onclick="parseMultiInput()">
                    <i class="ti ti-cpu"></i> Trích xuất xử lý dữ liệu
                </button>

                <div id="multiResult" class="d-none">
                    <form action="/Word/BulkCreate" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="table-responsive mb-4 rounded-3 border">
                            <table class="table table-hover align-middle mb-0 text-center" style="font-size: 14px;">
                                <thead class="table-light">
                                    <tr class="text-secondary" style="font-weight: 600;">
                                        <th class="text-start ps-3">Từ vựng / Phát âm</th>
                                        <th>Định nghĩa</th>
                                        <th>Thể loại</th>
                                        <th class="pe-3">Độ khó</th>
                                    </tr>
                                </thead>
                                <tbody id="multiTableBody" class="border-top-0"></tbody>
                            </table>
                        </div>
                        
                        <div id="hiddenInputsContainer"></div>

                        <button type="submit" class="save-btn w-100 py-3" style="font-size: 16px;">
                            <i class="ti ti-cloud-upload"></i> Xác nhận lưu tất cả (<span id="wordCount">0</span> từ vựng)
                        </button>
                    </form>
                </div>
            </div>
            
        </div>
    </div>
</div>

<style>
    /* Thanh chuyển đổi kiểu viên thuốc */
    .tab-navigation-bar {
        display: flex;
        background: var(--bg-hover);
        padding: 6px;
        border-radius: 12px;
        gap: 4px;
    }
    .tab-btn {
        flex: 1;
        border: none;
        background: transparent;
        padding: 10px 16px;
        font-size: 15px;
        font-weight: 600;
        color: var(--text-muted);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s ease;
    }
    .tab-btn i { font-size: 18px; }
    .tab-btn.active {
        background: var(--bg-card);
        color: var(--sidebar-active-text);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    /* Container bao quanh Form bọc trắng nền tinh tế */
    .form-section-box {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    }

    /* Thiết kế form nhập liệu siêu mượt */
    .custom-form-label {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-label);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 6px;
        display: block;
    }
    .custom-form-input {
        width: 100%;
        background: var(--bg-body);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 11px 16px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        transition: all 0.2s;
    }
    .custom-form-input:focus {
        background: var(--bg-card);
        border-color: var(--sidebar-active-text);
        outline: none;
        box-shadow: 0 0 0 3px rgba(109, 40, 217, 0.1);
    }
    .accent-input {
        border-color: #a78bfa;
        background: rgba(167, 139, 250, 0.03);
    }
    .hint-text { font-size: 12px; color: var(--text-label); margin-top: 6px; display: block; }

    /* Nút xử lý trung gian */
    .process-btn {
        background: #0284c7;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: background 0.15s;
    }
    .process-btn:hover { background: #0369a1; }

    /* Cụm nút lưu/hủy điều hướng */
    .action-btn-group { display: flex; gap: 12px; }
    .save-btn {
        flex: 2;
        background: var(--sidebar-active-text);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: opacity 0.15s;
    }
    .save-btn:hover { opacity: 0.9; color: white; }
    .cancel-btn {
        flex: 1;
        background: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        font-weight: 500;
        transition: background 0.15s;
    }
    .cancel-btn:hover { background: var(--bg-hover); color: var(--text-main); text-decoration: none; }
</style>

<script>
    function switchTab(formId, buttonElement) {
        // Ẩn toàn bộ form
        document.querySelectorAll('.form-section-box').forEach(el => el.classList.add('d-none'));
        // Xóa trạng thái active của nút cũ
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        
        // Hiển thị form được chọn và gán active cho nút hiện tại
        document.getElementById(formId).classList.remove('d-none');
        buttonElement.classList.add('active');
    }

    // --- Xử lý cho Nhập nhanh 1 Từ (Có hỗ trợ Pronunciation) ---
    function parseQuickInput() {
        const inputString = document.getElementById('autoTerm').value.trim();
        if (!inputString.includes('|')) return alert('Vui lòng điền đúng cú pháp ngăn cách bằng dấu "|"');
        
        const parts = inputString.split('|').map(item => item.trim());
        document.getElementById('resultTerm').value = parts[0] || '';
        document.getElementById('resultPronunciation').value = parts[1] || '';
        document.getElementById('resultDefinition').value = parts[2] || '';
        document.getElementById('resultCategory').value = parts[3] || '';
        document.getElementById('resultExample').value = parts[4] || '';

        let levelValue = "2";
        if (parts[5]) {
            const l = parts[5].toLowerCase();
            if (l.includes("dễ")) levelValue = "1";
            else if (l.includes("khó")) levelValue = "3";
        }
        document.getElementById('resultDifficultyLevel').value = levelValue;
        document.getElementById('autoResult').classList.remove('d-none');
    }

    // --- Xử lý Nhập Nhiều Từ (Bulk Create) ---
    function parseMultiInput() {
        const text = document.getElementById('multiTerm').value.trim();
        if (!text) return alert('Vui lòng điền văn bản dữ liệu đầu vào.');

        const lines = text.split('\n').filter(line => line.trim() !== '');
        const tbody = document.getElementById('multiTableBody');
        const hiddenContainer = document.getElementById('hiddenInputsContainer');
        
        tbody.innerHTML = '';
        hiddenContainer.innerHTML = '';
        let validCount = 0;

        lines.forEach((line) => {
            const parts = line.split('|').map(item => item.trim());
            
            if (parts.length >= 1 && parts[0] !== '') {
                const term = parts[0];
                const pronunciation = parts[1] || '';
                const definition = parts[2] || '';
                const category = parts[3] || '';
                const example = parts[4] || '';
                
                let levelValue = 2;
                let levelBadge = '<span class="badge bg-warning text-dark">Trung Bình</span>';
                
                if (parts[5]) {
                    const l = parts[5].toLowerCase();
                    if (l.includes("dễ")) { levelValue = 1; levelBadge = '<span class="badge bg-success">Dễ</span>'; }
                    else if (l.includes("khó")) { levelValue = 3; levelBadge = '<span class="badge bg-danger">Khó</span>'; }
                }

                // Append dòng dữ liệu xem trước vào Table
                tbody.innerHTML += `
                    <tr>
                        <td class="text-start ps-3">
                            <div class="fw-bold text-primary" style="font-size:15px;">${term}</div>
                            <div class="text-muted font-monospace" style="font-size:12px;">${pronunciation}</div>
                        </td>
                        <td class="text-secondary">${definition}</td>
                        <td><span class="badge bg-light text-dark border text-uppercase" style="letter-spacing:0.02em;">${category}</span></td>
                        <td class="pe-3">${levelBadge}</td>
                    </tr>
                `;

                // Tạo thẻ input ẩn đẩy dữ liệu lên POST BulkCreate
                hiddenContainer.innerHTML += `
                    <input type="hidden" name="words[${validCount}].Term" value="${term}">
                    <input type="hidden" name="words[${validCount}].Pronunciation" value="${pronunciation}">
                    <input type="hidden" name="words[${validCount}].Definition" value="${definition}">
                    <input type="hidden" name="words[${validCount}].Category" value="${category}">
                    <input type="hidden" name="words[${validCount}].Example" value="${example}">
                    <input type="hidden" name="words[${validCount}].DifficultyLevel" value="${levelValue}">
                `;
                
                validCount++;
            }
        });

        if (validCount === 0) return alert('Không tìm thấy bản ghi từ vựng hợp lệ.');

        document.getElementById('wordCount').innerText = validCount;
        document.getElementById('multiResult').classList.remove('d-none');
    }
</script>
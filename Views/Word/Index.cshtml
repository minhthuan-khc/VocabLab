@model IEnumerable<Word>

@{
    ViewData["Title"] = "Danh Sách Từ Vựng";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2>📚 Các Từ Đã Lưu</h2>
                    <p class="text-muted mb-0">Tổng số từ: <strong>@(Model?.Count() ?? 0)</strong></p>
                </div>
                <a href="@Url.Action("Create", "Word")" class="btn btn-success btn-lg">
                    ➕ Thêm Từ Mới
                </a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Từ</th>
                                <th>Định Nghĩa</th>
                                <th>Thể Loại</th>
                                <th>Ví Dụ</th>
                                <th>Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var word in Model)
                            {
                                <tr>
                                    <td><strong>@word.Term</strong></td>
                                    <td>@word.Definition</td>
                                    <td>
                                        <span class="badge bg-info">@word.Category</span>
                                    </td>
                                    <td>@word.Example</td>
                                    <td>
                                        <a href="@Url.Action("Edit", "Word", new { id = word.Id })" class="btn btn-sm btn-primary">
                                            ✏️ Sửa
                                        </a>
                                        <a href="@Url.Action("Delete", "Word", new { id = word.Id })" class="btn btn-sm btn-danger" onclick="return confirm('Bạn chắc chắn muốn xóa?')">
                                            🗑️ Xóa
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <h4 class="alert-heading">📭 Chưa có từ vựng</h4>
                    <p>Bạn chưa thêm từ vựng nào. Hãy bấm nút "<strong>Thêm Từ Mới</strong>" để bắt đầu!</p>
                </div>
            }

            <hr class="my-5">

           
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
    }

    .btn-lg {
        padding: 0.8rem 1.5rem;
        font-size: 1.1rem;
    }

    .alert {
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    h2 {
        font-weight: 700;
        color: #333;
    }
</style>

@{ ViewData["Title"] = "Luyện tập Flashcard"; }
<style>
    .game-container { max-width: 600px; margin: 4rem auto; text-align: center; }
    .flashcard-wrapper { perspective: 1000px; margin-bottom: 2rem; }
    .flashcard { width: 100%; height: 300px; transform-style: preserve-3d; transition: transform 0.6s; cursor: pointer; position: relative; }
    .flashcard.flipped { transform: rotateY(180deg); }
    .card-face { position: absolute; width: 100%; height: 100%; backface-visibility: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; border-radius: 16px; background: var(--bg-card); border: 2px solid var(--border-color); box-shadow: var(--shadow-card); padding: 2rem; }
    .card-back { transform: rotateY(180deg); background: var(--bg-select); }
    .btn-action { padding: 10px 24px; border-radius: 20px; border: none; font-weight: 600; cursor: pointer; margin: 0 10px; }
    .btn-next { background: #3b82f6; color: white; }
</style>

<div class="game-container">
    <h3 class="mb-4">Thẻ ghi nhớ (Flashcard)</h3>
    <div class="flashcard-wrapper">
        <div class="flashcard" id="flashcard" onclick="this.classList.toggle('flipped')">
            <div class="card-face card-front">
                <h1 id="word-eng" style="color: var(--text-main)">Loading...</h1>
                <p id="word-pron" style="color: var(--text-label)">...</p>
                <button class="btn btn-sm btn-light" onclick="event.stopPropagation(); playAudio()"><i class="ti ti-volume"></i> Nghe</button>
            </div>
            <div class="card-face card-back">
                <h2 id="word-vie" style="color: #3b82f6">...</h2>
            </div>
        </div>
    </div>
    <button class="btn-action btn-next" onclick="nextCard()">Từ tiếp theo →</button>
</div>

<script>
    let words = [];
    let currentIndex = 0;

    async function loadWords() {
        const res = await fetch('/Word/GetWordsForGame?sort=Ngẫu nhiên&count=10');
        words = await res.json();
        if(words.length > 0) showCard();
    }

    function showCard() {
        document.getElementById("flashcard").classList.remove('flipped');
        setTimeout(() => {
            document.getElementById("word-eng").innerText = words[currentIndex].english;
            document.getElementById("word-pron").innerText = words[currentIndex].pronunciation;
            document.getElementById("word-vie").innerText = words[currentIndex].vietnamese;
        }, 200);
    }

    function nextCard() {
        currentIndex = (currentIndex + 1) % words.length;
        showCard();
    }

    function playAudio() {
        new Audio(words[currentIndex].audioUrl).play();
    }

    document.addEventListener("DOMContentLoaded", loadWords);
</script>
@{ ViewData["Title"] = "Luyện tập Flashcard"; }

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
    /* Biến màu sắc tự động theo data-theme hệ thống */
    :root {
        --bg-app: #f8fafc;          
        --bg-card-front: #5bc0be;   
        --bg-card-back: #ffffff;    
        --text-main: #1e293b;       
        --text-card-back: #0f172a;  
        --bg-topbar: rgba(0, 0, 0, 0.05);
        --text-topbar: #334155;
        --border-input: #cbd5e1;
        --bg-input: #ffffff;
        --text-input: #0f172a;
    }

    [data-theme="dark"] {
        --bg-app: #0f172a;          
        --bg-card-front: #3a8e8d;   
        --bg-card-back: #1e293b;    
        --text-main: #f8fafc;       
        --text-card-back: #f1f5f9;  
        --bg-topbar: rgba(255, 255, 255, 0.1);
        --text-topbar: #cbd5e1;
        --border-input: #334155;
        --bg-input: #1e293b;
        --text-input: #f8fafc;
    }

    .game-wrapper {
        background-color: var(--bg-app);
        min-height: 100vh;
        padding: 2rem 1rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-main);
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Top Bar */
    .top-bar {
        background: var(--bg-topbar);
        border: 1px solid rgba(128, 128, 128, 0.2);
        border-radius: 50px;
        padding: 8px 24px;
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 2rem;
        font-size: 14px;
        width: 100%;
        max-width: 550px;
        justify-content: space-between;
        color: var(--text-topbar);
    }
    .game-mode {
        background: #f59e0b;
        color: black;
        font-weight: bold;
        padding: 2px 8px;
        border-radius: 12px;
    }
    
    .top-bar-right {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    .top-bar a {
        color: inherit;
        text-decoration: none;
    }
    .top-bar a:hover { opacity: 0.8; }

    /* Flashcard Container */
    .flashcard-container {
        width: 100%;
        max-width: 550px;
        perspective: 1000px;
        margin-bottom: 1.5rem;
    }
    .flashcard {
        width: 100%;
        height: 320px;
        transform-style: preserve-3d;
        transition: transform 0.4s ease;
        cursor: pointer;
        position: relative;
    }
    .flashcard.flipped {
        transform: rotateY(180deg);
    }
    .card-face {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 24px;
        padding: 2.5rem; /* Giữ khoảng cách lề khoảng 3cm cân đối */
        display: flex;
        flex-direction: column;
        justify-content: center; 
        align-items: center;     
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        transition: background-color 0.3s ease;
        overflow: hidden; 
    }
    
    .card-front {
        background-color: var(--bg-card-front); 
        color: #ffffff;
    }
    .card-back {
        background-color: var(--bg-card-back);
        color: var(--text-card-back);
        transform: rotateY(180deg);
        border: 1px solid rgba(128, 128, 128, 0.2);
    }

    .card-label {
        font-size: 11px; 
        text-transform: uppercase;
        letter-spacing: 2px;
        opacity: 0.8;
        margin-bottom: 0.5rem;
    }

    /* Các class định cỡ chữ linh hoạt được kiểm soát bằng JS bên dưới */
    .card-word-eng {
        font-weight: 800;
        margin-bottom: 0.5rem;
        word-break: break-word; 
        text-align: center;
        line-height: 1.2;
        max-width: 100%; 
        transition: font-size 0.15s ease;
    }
    .card-word-eng.single-word { font-size: 2.8rem; }
    .card-word-eng.multi-word  { font-size: 1.8rem; } /* Hạ size khi từ dài/cụm từ */

    .card-word-vie {
        font-weight: 700;
        margin-bottom: 0.5rem;
        word-break: break-word;
        text-align: center;
        line-height: 1.2;
        max-width: 100%;
        transition: font-size 0.15s ease;
    }
    .card-word-vie.single-word { font-size: 2.2rem; }
    .card-word-vie.multi-word  { font-size: 1.6rem; } /* Hạ size khi nghĩa dài/nhiều từ */

    .card-pronun {
        font-size: 1.2rem; 
        opacity: 0.9;
        margin-bottom: 1rem;
    }
    .card-example {
        font-style: italic;
        font-size: 14px; 
        margin-top: 15px;
        text-align: center;
        background: rgba(128, 128, 128, 0.15);
        padding: 8px 16px; 
        border-radius: 12px;
        max-width: 90%;
        line-height: 1.4;
    }
    
    .btn-audio {
        background: transparent;
        border: none;
        color: white;
        font-size: 22px; 
        cursor: pointer;
        opacity: 0.8;
        transition: 0.2s;
        margin-top: 10px;
    }
    .btn-audio:hover { opacity: 1; transform: scale(1.1); }

    .flip-hint {
        font-size: 12px;
        color: #f59e0b;
        margin-bottom: 1.5rem;
        font-weight: 500;
    }

    /* Ô gõ text kiểm tra */
    .input-box-wrapper {
        width: 100%;
        max-width: 400px;
        display: flex;
        background: var(--bg-input);
        border-radius: 30px;
        padding: 5px 5px 5px 15px;
        align-items: center;
        margin-bottom: 2rem;
        border: 2px solid var(--border-input);
        transition: background-color 0.3s, border-color 0.3s;
    }
    .input-box-wrapper input {
        background: transparent;
        border: none;
        color: var(--text-input);
        flex: 1;
        outline: none;
        font-size: 14px;
    }
    .btn-check-submit {
        background: #22c55e;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 20px;
        font-weight: bold;
        cursor: pointer;
    }

    /* Thanh điều khiển bên dưới */
    .bottom-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        width: 100%;
        max-width: 600px;
        flex-wrap: wrap;
    }
    .btn-nav-small {
        background: transparent;
        border: none;
        color: #64748b;
        cursor: pointer;
        font-size: 14px;
    }
    .btn-nav-small:hover { color: var(--text-main); }
    
    .btn-circle-audio {
        background: #22c55e;
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .btn-status {
        padding: 10px 28px;
        border-radius: 25px;
        border: none;
        font-weight: bold;
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 15px;
        transition: 0.2s;
    }
    .btn-status.quen { background: #ef4444; } 
    .btn-status.thuoc { background: #22c55e; } 
    .btn-status:hover { opacity: 0.9; transform: translateY(-1px); }

    .hotkey-hints {
        display: flex;
        justify-content: center;
        gap: 20px;
        font-size: 11px;
        color: #94a3b8;
        margin-top: 15px;
        width: 100%;
    }
</style>

<div class="game-wrapper">
    <div class="top-bar">
        <div>
            <span class="game-mode">~0 GAME</span> 
            <span id="game-progress" style="margin-left: 5px; font-weight: bold;">1 / 20</span>
        </div>
        
        <div class="top-bar-right">
            <a href="javascript:void(0)" onclick="restartGame()"><i class="bi bi-arrow-clockwise"></i> Chơi lại</a>
            <a href="/Word/Quiz"><i class="bi bi-box-arrow-right"></i> Thoát</a>
        </div>
    </div>

    <div class="flashcard-container">
        <div class="flashcard" id="flashcard" onclick="toggleFlip()">
            
            <div class="card-face card-front">
                <div class="card-label">Tiếng Anh</div>
                <div class="card-word-eng" id="word-eng">branch</div>
                <div class="card-pronun" id="word-pron">/bræntʃ/</div>
                <button class="btn-audio" onclick="event.stopPropagation(); playAudio()">
                    <i class="bi bi-volume-up-fill"></i>
                </button>
            </div>
            
            <div class="card-face card-back">
                <div class="card-label">Nghĩa Tiếng Việt</div>
                <div class="card-word-vie" id="word-vie" style="color: #f59e0b;">chi nhánh</div>
                <div class="card-example" id="word-example">Ví dụ: "This branch opens at 9 AM"</div>
            </div>

        </div>
    </div>

    <div class="flip-hint">
        <i class="bi bi-hand-index-thumb"></i> Nhấn Space hoặc click để lật lại
    </div>

    <div class="input-box-wrapper">
        <input type="text" id="user-input" placeholder="Gõ nghĩa (Đánh dấu đã thuộc nếu thấy đúng)">
        <button class="btn-check-submit" onclick="checkAnswer()">Check</button>
    </div>

    <div class="bottom-actions">
        <button class="btn-nav-small" onclick="prevCard()">&lt; Trước</button>
        
        <button class="btn-circle-audio" onclick="playAudio()"><i class="bi bi-volume-up-fill"></i></button>
        
        <button class="btn-status quen" onclick="markQuen()"><i class="bi bi-xlg"></i> Quên</button>
        <button class="btn-status thuoc" onclick="markThuoc()"><i class="bi bi-check-lg"></i> Thuộc</button>
        
        <button class="btn-nav-small" onclick="nextCard()">Tiếp &gt;</button>
    </div>

    <div class="hotkey-hints">
        <span>Ctrl+&larr; khi nhớ</span>
        <span>Ctrl+S khi nhập</span>
        <span>Ctrl+1/X khi nhập</span>
        <span>Ctrl+2/C khi nhập</span>
        <span>Ctrl+&rarr; khi nhập</span>
    </div>
</div>

<script>
    let words = [];
    let currentIndex = 0;

    async function loadWords() {
        try {
            const res = await fetch('/Word/GetWordsForGame?sort=Ngẫu nhiên&count=10');
            words = await res.json();
            
            if(words && words.length > 0) {
                showCard();
            } else {
                initMockData();
            }
        } catch (e) {
            initMockData();
        }
    }

    function initMockData() {
        words = [
            { english: "branch", pronunciation: "/bræntʃ/", vietnamese: "chi nhánh", example: 'Ví dụ: "This branch opens at 9 AM"', audioUrl: "" },
            { english: "subsidiary company", pronunciation: "/səbˈsɪdiəri ˈkʌmpəni/", vietnamese: "công ty con thành viên", example: 'Ví dụ: "A subsidiary company."', audioUrl: "" },
            { english: "headquarters", pronunciation: "/ˈhedkwɔːrtərz/", vietnamese: "trụ sở chính và cơ quan điều hành đầu não", example: 'Ví dụ: "The company headquarters is in Paris."', audioUrl: "" }
        ];
        showCard();
    }

    // Hàm tự động tính toán số lượng từ để xử lý class font-size linh hoạt
    function adjustFontSize(text, element, type) {
        // Cắt bỏ khoảng trắng thừa và split theo khoảng trắng để đếm từ
        const wordCount = text.trim().split(/\s+/).length;
        
        element.classList.remove('single-word', 'multi-word');
        
        // Nếu chuỗi chứa từ 2 từ trở lên hoặc có độ dài ký tự quá lớn (> 15 ký tự)
        if (wordCount >= 2 || text.length > 15) {
            element.classList.add('multi-word');
        } else {
            element.classList.add('single-word');
        }
    }

    function showCard() {
        const card = document.getElementById("flashcard");
        card.classList.remove('flipped'); 
        
        document.getElementById("user-input").value = ""; 
        document.getElementById("game-progress").innerText = `${currentIndex + 1} / ${words.length}`;

        setTimeout(() => {
            const current = words[currentIndex];
            
            const engElem = document.getElementById("word-eng");
            const vieElem = document.getElementById("word-vie");

            // Đổ text vào trước
            engElem.innerText = current.english;
            vieElem.innerText = current.vietnamese;
            
            // Chạy hàm kiểm tra để tự gán class font-size thích hợp
            adjustFontSize(current.english, engElem, 'eng');
            adjustFontSize(current.vietnamese, vieElem, 'vie');

            document.getElementById("word-pron").innerText = current.pronunciation || "";
            document.getElementById("word-example").innerText = current.example || `Ví dụ với từ "${current.english}"`;
        }, 150);
    }

    function toggleFlip() {
        document.getElementById("flashcard").classList.toggle('flipped');
    }

    function nextCard() {
        if(words.length === 0) return;
        currentIndex = (currentIndex + 1) % words.length;
        showCard();
    }

    function prevCard() {
        if(words.length === 0) return;
        currentIndex = (currentIndex - 1 + words.length) % words.length;
        showCard();
    }

    function markQuen() { nextCard(); }
    function markThuoc() { nextCard(); }

    function checkAnswer() {
        const input = document.getElementById("user-input").value.trim().toLowerCase();
        const target = words[currentIndex].vietnamese.toLowerCase();
        
        if(input && target.includes(input)) {
            alert("Chính xác!");
            toggleFlip();
        } else {
            alert(`Chưa chính xác! Nghĩa đúng là: ${words[currentIndex].vietnamese}`);
        }
    }

    function playAudio() {
        if(words[currentIndex] && words[currentIndex].audioUrl) {
            new Audio(words[currentIndex].audioUrl).play();
        } else {
            let utterance = new SpeechSynthesisUtterance(words[currentIndex].english);
            utterance.lang = 'en-US';
            window.speechSynthesis.speak(utterance);
        }
    }

    function restartGame() {
        currentIndex = 0;
        document.getElementById("flashcard").classList.remove('flipped');
        loadWords();
    }

    document.addEventListener("keydown", function(event) {
        if (event.code === "Space" && document.activeElement.id !== "user-input") {
            event.preventDefault();
            toggleFlip();
        }
        if (event.code === "Enter" && document.activeElement.id === "user-input") {
            checkAnswer();
        }
    });

    document.addEventListener("DOMContentLoaded", loadWords);
</script>
@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    /* 1. HỆ THỐNG BIẾN MÀU ĐỒNG BỘ */
    :root {
        --bg-card: #ffffff;
        --border-color: #e2e8f0;
        --text-main: #0f172a;
        --text-muted: #475569;
        --text-label: #64748b;
        --bg-hover: #f1f5f9;
        --shadow-card: 0 1px 3px rgba(0,0,0,0.05);
        
        --color-purple: #6d28d9;
        --color-green: #16a34a;
        --color-amber: #d97706;
        --color-red: #dc2626;
        
        --icon-bg-purple: #eeedfe;
        --icon-bg-teal: #e1f5ee;
        --icon-bg-amber: #faeeda;
        --icon-bg-blue: #e6f1fb;
    }

    [data-theme="dark"] {
        --bg-card: #1e293b;
        --border-color: #334155;
        --text-main: #f8fafc;
        --text-muted: #cbd5e1;
        --text-label: #94a3b8;
        --bg-hover: #334155;
        --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.2);
        
        --color-purple: #a78bfa;
        --color-green: #4ade80;
        --color-amber: #fbbf24;
        --color-red: #f87171;
        
        --icon-bg-purple: #312e81;
        --icon-bg-teal: #064e3b;
        --icon-bg-amber: #78350f;
        --icon-bg-blue: #1e3a8a;
    }

    /* 2. PHÂN CHIA BỐ CỤC BẤT ĐỐI XỨNG (ĐÁNH BẠT CỘT TRÁI) */
    .top-section {
        display: grid;
        grid-template-columns: 1.8fr 1fr; /* Cột trái to vượt trội để làm nổi bật tiến trình */
        gap: 24px;
        align-items: start;
        margin-bottom: 2rem;
    }

    .page-title { font-size: 24px; font-weight: 700; color: var(--text-main); margin-bottom: 1.5rem; letter-spacing: -0.02em; }
    .section-title { font-size: 16px; font-weight: 700; margin-bottom: 1rem; color: var(--text-main); display: flex; align-items: center; gap: 6px; }

    .dashboard-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        box-shadow: var(--shadow-card);
        height: 100%;
    }

    /* 3. THIẾT KẾ CỘT TRÁI: KHỐI TIẾN TRÌNH LỚN, ĐẬM NÉT */
    .stats-large-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
    .stat-focus-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 1.5rem; /* Tăng padding để card nhìn bề thế, quan trọng */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: var(--shadow-card);
        position: relative;
        overflow: hidden;
    }
    /* Đánh dấu điểm nhấn riêng cho ô tiến độ chính */
    .stat-focus-card.main-progress {
        grid-column: span 2; /* Trải dài cả 2 cột để tạo khối tiến trình lớn */
        border-left: 5px solid var(--color-purple);
    }
    
    .stat-header-inline { display: flex; align-items: center; gap: 12px; margin-bottom: 0.5rem; }
    .stat-focus-label { font-size: 14px; font-weight: 700; color: var(--text-label); text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-focus-value { font-size: 32px; font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; }
    
    .stat-focus-value.purple { color: var(--color-purple); }
    .stat-focus-value.green  { color: var(--color-green); }
    .stat-focus-value.amber  { color: var(--color-amber); }
    .stat-focus-value.red    { color: var(--color-red); }

    .stat-focus-sub { font-size: 13px; color: var(--text-muted); margin-top: 4px; font-weight: 500; }
    
    /* Thanh Progress Bar bự và trực quan chạy dọc khung hình */
    .progress-bar-large { height: 10px; background: var(--border-color); border-radius: 5px; margin-top: 14px; overflow: hidden; width: 100%; }
    .progress-fill-large { height: 100%; background: linear-gradient(90deg, var(--color-purple), #a78bfa); border-radius: 5px; }
    .stat-focus-card .quick-icon { width: 40px; height: 40px; font-size: 20px; border-radius: 10px; display: flex; align-items: center; justify-content: center; }

    /* 4. THIẾT KẾ CỘT PHẢI: KHUNG LỊCH MINI RÚT GỌN (WIDGET) */
    .calendar-mini-card { padding: 1rem; height: fit-content; } /* Thu nhỏ padding */
    .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; }
    .calendar-month-year { font-size: 14px; font-weight: 700; color: var(--text-main); }
    
    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; text-align: center; }
    .calendar-day-label { font-size: 10px; font-weight: 700; color: var(--text-label); padding-bottom: 2px; }
    
    .calendar-day { 
        font-size: 11px; /* Chữ lịch nhỏ lại xinh xắn */
        font-weight: 600; 
        aspect-ratio: 1; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        border-radius: 6px; 
        color: var(--text-muted);
    }
    .calendar-day.empty { opacity: 0; }
    .calendar-day.today { border: 1.5px solid var(--color-purple); font-weight: 700; color: var(--color-purple); }
    .calendar-day.streak-done { background: var(--icon-bg-purple); color: var(--color-purple); font-weight: 700; }

    /* 5. KHỐI THAO TÁC NHANH DÀN NGANG */
    .quick-grid-horizontal { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .quick-card-horiz { 
        background: var(--bg-card); 
        border: 1px solid var(--border-color); 
        border-radius: 12px; 
        padding: 1.25rem; 
        display: flex; 
        flex-direction: column;
        gap: 10px; 
        text-decoration: none; 
        color: inherit; 
        box-shadow: var(--shadow-card);
        transition: all 0.2s ease; 
    }
    .quick-card-horiz:hover { background: var(--bg-hover); transform: translateY(-3px); text-decoration: none; color: inherit; }
    .quick-card-horiz .quick-icon { width: 38px; height: 38px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .quick-card-horiz .quick-icon.purple { background: var(--icon-bg-purple); color: var(--color-purple); }
    .quick-card-horiz .quick-icon.teal   { background: var(--icon-bg-teal); color: var(--color-green); }
    .quick-card-horiz .quick-icon.amber  { background: var(--icon-bg-amber); color: var(--color-amber); }
    .quick-card-horiz .quick-icon.blue   { background: var(--icon-bg-blue); color: #3b82f6; }
    .quick-horiz-title { font-size: 14px; font-weight: 700; color: var(--text-main); }
    .quick-horiz-sub { font-size: 12px; color: var(--text-label); line-height: 1.3; }

    @@media (max-width: 900px) {
        .top-section { grid-template-columns: 1fr; }
        .quick-grid-horizontal { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="page-title">👋 Xin chào, @(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "bạn")!</div>

<!-- TẦNG 1: TỔNG QUAN LỚN VÀ LỊCH WIDGET MINI NHỎ GỌN -->
<div class="top-section">
    
    <!-- Cột trái: Đánh bật tổng quan tiến trình học tập -->
    <div>
        <div class="section-title"><i class="ti ti-chart-bar"></i> Tiến trình học tập của bạn</div>
        <div class="stats-large-grid">
            
            <!-- Card bự nhất: Thống kê tổng từ và thanh tiến độ dài trực quan -->
            <div class="stat-focus-card main-progress">
                <div>
                    <div class="stat-header-inline">
                        <div class="quick-icon purple"><i class="ti ti-books"></i></div>
                        <span class="stat-focus-label">Học lực kho từ vựng</span>
                    </div>
                    <div style="display: flex; align-items: baseline; gap: 10px;">
                        <span class="stat-focus-value purple">@ViewBag.LearnedWords</span>
                        <span style="color: var(--text-label); font-size: 15px; font-weight: 500;">/ @ViewBag.TotalWords từ đã thuộc</span>
                    </div>
                </div>
                <div>
                    <div class="progress-bar-large">
                        <div class="progress-fill-large" style="width: @ViewBag.Progress%"></div>
                    </div>
                    <div class="stat-focus-sub" style="text-align: right; color: var(--color-purple)">Đạt @ViewBag.Progress% mục tiêu</div>
                </div>
            </div>
            
            <!-- Các ô trạng thái nhỏ bổ trợ ở dưới -->
            <div class="stat-focus-card">
                <div class="stat-header-inline">
                    <div class="quick-icon amber"><i class="ti ti-flame"></i></div>
                    <span class="stat-focus-label">Chuỗi ngày</span>
                </div>
                <span class="stat-focus-value amber">@ViewBag.Streak ngày</span>
                <span class="stat-focus-sub">Học tập đều đặn</span>
            </div>
            
            <div class="stat-focus-card">
                <div class="stat-header-inline">
                    <div class="quick-icon red"><i class="ti ti-alert-circle"></i></div>
                    <span class="stat-focus-label">Từ cần ôn</span>
                </div>
                <span class="stat-focus-value red">@ViewBag.DueWords từ</span>
                <span class="stat-focus-sub" style="color: var(--color-red); font-weight:600;">Đến hạn ôn tập (SRS)</span>
            </div>
            
        </div>
    </div>

    <!-- Cột phải: Lịch Tháng thu gọn thành một ô Widget tiện ích nhỏ -->
    <div>
        <div class="section-title"><i class="ti ti-calendar"></i> Ghi nhận chuyên cần</div>
        <div class="dashboard-card calendar-mini-card">
            <div class="calendar-header">
                <span class="calendar-month-year" id="calendarTitle">Tháng --/----</span>
                <span style="font-size: 11px; color: var(--text-label); font-weight: 600;">Check-in</span>
            </div>
            <div class="calendar-grid" id="calendarGrid">
                <!-- Tiêu đề thứ -->
                <div class="calendar-day-label">Hai</div>
                <div class="calendar-day-label">Ba</div>
                <div class="calendar-day-label">Tư</div>
                <div class="calendar-day-label">Năm</div>
                <div class="calendar-day-label">Sáu</div>
                <div class="calendar-day-label">Bảy</div>
                <div class="calendar-day-label">CN</div>
                <!-- JS sinh tự động ngày nhỏ ở đây -->
            </div>
        </div>
    </div>
</div>

<!-- TẦNG 2: THAO TÁC NHANH -->
<div class="section-title"><i class="ti ti-direction"></i> Thao tác nhanh</div>
<div class="quick-grid-horizontal">
    <a class="quick-card-horiz" asp-controller="Word" asp-action="Create">
        <div class="quick-icon purple"><i class="ti ti-plus"></i></div>
        <div class="quick-horiz-title">Thêm từ mới</div>
        <div class="quick-horiz-sub">Bổ sung từ vựng cá nhân vào kho lưu trữ.</div>
    </a>
    
    <a class="quick-card-horiz" asp-controller="Word" asp-action="Quiz">
        <div class="quick-icon teal"><i class="ti ti-bolt"></i></div>
        <div class="quick-horiz-title">Luyện tập</div>
        <div class="quick-horiz-sub">Lật thẻ flashcard, trắc nghiệm phản xạ nhanh.</div>
    </a>
    
    <a class="quick-card-horiz" asp-controller="Word" asp-action="Index">
        <div class="quick-icon amber"><i class="ti ti-list"></i></div>
        <div class="quick-horiz-title">Sổ từ vựng</div>
        <div class="quick-horiz-sub">Xem, tra cứu và quản lý bộ từ đang sở hữu.</div>
    </a>
    
    <a class="quick-card-horiz" asp-controller="Home" asp-action="Privacy">
        <div class="quick-icon blue"><i class="ti ti-trophy"></i></div>
        <div class="quick-horiz-title">Xếp hạng</div>
        <div class="quick-horiz-sub">Thi đua điểm số tích lũy cùng học viên khác.</div>
    </a>
</div>

<!-- KỊCH BẢN TỰ ĐỘNG DỰNG LỊCH MINI -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const date = new Date();
        const currentYear = date.getFullYear();
        const currentMonth = date.getMonth(); 
        const todayDate = date.getDate();

        document.getElementById("calendarTitle").textContent = `Tháng ${currentMonth + 1} / ${currentYear}`;
        const grid = document.getElementById("calendarGrid");

        let firstDayIndex = new Date(currentYear, currentMonth, 1).getDay();
        firstDayIndex = firstDayIndex === 0 ? 6 : firstDayIndex - 1;

        const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

        for (let i = 0; i < firstDayIndex; i++) {
            const emptyDiv = document.createElement("div");
            emptyDiv.className = "calendar-day empty";
            grid.appendChild(emptyDiv);
        }

        for (let day = 1; day <= totalDays; day++) {
            const dayDiv = document.createElement("div");
            dayDiv.className = "calendar-day";
            dayDiv.textContent = day;

            if (day === todayDate) {
                dayDiv.classList.add("today");
            }

            // Mẫu chuỗi ngày đã học (Bạn có thể map dữ liệu từ DB vào đây)
            const sampleStreakDays = [1, 2, 3, 4, 10, 11, 12, 18, 19, todayDate]; 
            if (sampleStreakDays.includes(day)) {
                dayDiv.classList.add("streak-done");
            }

            grid.appendChild(dayDiv);
        }
    });
</script>
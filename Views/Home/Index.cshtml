@{
    ViewData["Title"] = "Trang chủ";
}

<style>
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 1.5rem; }
    .stat-card { background: #fff; border: 1px solid #e5e5e0; border-radius: 10px; padding: 1rem 1.25rem; }
    .stat-label { font-size: 12px; color: #888; margin-bottom: 6px; }
    .stat-value { font-size: 26px; font-weight: 600; }
    .stat-value.purple { color: #7F77DD; }
    .stat-value.green  { color: #1D9E75; }
    .stat-value.amber  { color: #BA7517; }
    .stat-value.red    { color: #E24B4A; }
    .stat-sub { font-size: 11px; margin-top: 4px; }
    .progress-bar-custom { height: 6px; background: #eee; border-radius: 3px; margin-top: 8px; }
    .progress-fill { height: 100%; border-radius: 3px; background: #7F77DD; }

    .streak-card { background: #fff; border: 1px solid #e5e5e0; border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; }
    .streak-title { font-size: 13px; font-weight: 500; color: #888; margin-bottom: 1rem; }
    .streak-days { display: flex; gap: 10px; }
    .day-item { display: flex; flex-direction: column; align-items: center; gap: 4px; font-size: 11px; color: #888; }
    .day-dot { width: 34px; height: 34px; border-radius: 50%; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 14px; }
    .day-dot.done { background: #534AB7; border-color: #534AB7; color: #fff; }
    .day-dot.today { background: #EEEDFE; border-color: #7F77DD; color: #534AB7; }

    .quick-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 1.5rem; }
    .quick-card { background: #fff; border: 1px solid #e5e5e0; border-radius: 10px; padding: 1rem 1.25rem; display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit; transition: background 0.15s; }
    .quick-card:hover { background: #f5f5f0; text-decoration: none; color: inherit; }
    .quick-icon { width: 42px; height: 42px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .quick-icon.purple { background: #EEEDFE; color: #534AB7; }
    .quick-icon.teal   { background: #E1F5EE; color: #0F6E56; }
    .quick-icon.amber  { background: #FAEEDA; color: #854F0B; }
    .quick-icon.blue   { background: #E6F1FB; color: #185FA5; }
    .quick-title { font-size: 14px; font-weight: 500; }
    .quick-sub { font-size: 12px; color: #888; margin-top: 2px; }

    .section-title { font-size: 15px; font-weight: 500; margin-bottom: 0.75rem; color: #222; }
    .topic-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .topic-chip { background: #fff; border: 1px solid #e5e5e0; border-radius: 20px; padding: 6px 14px; font-size: 12px; color: #555; cursor: pointer; transition: all 0.15s; }
    .topic-chip:hover, .topic-chip.active { background: #EEEDFE; color: #534AB7; border-color: #AFA9EC; }

    .page-title { font-size: 20px; font-weight: 600; color: #222; margin-bottom: 1.5rem; }
</style>

<div class="page-title">👋 Xin chào, @(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "bạn")!</div>

<!-- Thống kê -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Tổng từ</div>
        <div class="stat-value purple">@ViewBag.TotalWords</div>
        <div class="progress-bar-custom">
            <div class="progress-fill" style="width: @ViewBag.Progress%"></div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Đã thuộc</div>
        <div class="stat-value green">@ViewBag.LearnedWords</div>
        <div class="stat-sub" style="color:#1D9E75">@ViewBag.Progress% tiến độ</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Chuỗi ngày học</div>
        <div class="stat-value amber">@ViewBag.Streak ngày</div>
        <div class="stat-sub" style="color:#BA7517">Tiếp tục cố lên!</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Từ đến hạn</div>
        <div class="stat-value red">@ViewBag.DueWords</div>
        <div class="stat-sub" style="color:#E24B4A">Cần ôn tập</div>
    </div>
</div>

<!-- Chuỗi ngày -->
<div class="streak-card">
    <div class="streak-title">🔥 Chuỗi ngày học tuần này</div>
    <div class="streak-days">
        @foreach (var day in new[] { "T2","T3","T4","T5","T6","CN","T7" })
        {
            <div class="day-item">
                <div class="day-dot done">✓</div>
                <span>@day</span>
            </div>
        }
    </div>
</div>

<!-- Truy cập nhanh -->
<div class="section-title">Truy cập nhanh</div>
<div class="quick-grid">
    <a class="quick-card" asp-controller="Word" asp-action="Create">
        <div class="quick-icon purple"><i class="ti ti-plus"></i></div>
        <div>
            <div class="quick-title">Thêm từ mới</div>
            <div class="quick-sub">Tạo từ vựng cá nhân</div>
        </div>
        <i class="ti ti-arrow-right" style="margin-left:auto;color:#bbb"></i>
    </a>
    <a class="quick-card" asp-controller="Word" asp-action="Quiz">
        <div class="quick-icon teal"><i class="ti ti-bolt"></i></div>
        <div>
            <div class="quick-title">Luyện tập</div>
            <div class="quick-sub">Flashcard &amp; Quiz</div>
        </div>
        <i class="ti ti-arrow-right" style="margin-left:auto;color:#bbb"></i>
    </a>
    <a class="quick-card" asp-controller="Word" asp-action="Index">
        <div class="quick-icon amber"><i class="ti ti-books"></i></div>
        <div>
            <div class="quick-title">Bộ từ vựng</div>
            <div class="quick-sub">Xem tất cả từ</div>
        </div>
        <i class="ti ti-arrow-right" style="margin-left:auto;color:#bbb"></i>
    </a>
    <a class="quick-card" asp-controller="Home" asp-action="Privacy">
        <div class="quick-icon blue"><i class="ti ti-trophy"></i></div>
        <div>
            <div class="quick-title">Xếp hạng</div>
            <div class="quick-sub">Xem thành tích</div>
        </div>
        <i class="ti ti-arrow-right" style="margin-left:auto;color:#bbb"></i>
    </a>
</div>

<!-- Lọc chủ đề -->
<div class="section-title">Lộ trình học</div>
<div class="topic-chips">
    <a class="topic-chip active" asp-controller="Word" asp-action="Index">Tất cả</a>
    <a class="topic-chip" asp-controller="Word" asp-action="Index" asp-route-category="Food">Food</a>
    <a class="topic-chip" asp-controller="Word" asp-action="Index" asp-route-category="Animals">Animals</a>
    <a class="topic-chip" asp-controller="Word" asp-action="Index" asp-route-category="Travel">Travel</a>
    <a class="topic-chip" asp-controller="Word" asp-action="Index" asp-route-category="Business">Business</a>
    <a class="topic-chip" asp-controller="Word" asp-action="Index" asp-route-category="Technology">Technology</a>
</div>